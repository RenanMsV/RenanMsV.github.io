<div class="project-card opacity-0 translate-y-4 transition duration-700
            flex gap-4 items-start
            bg-white dark:bg-gray-900
            p-4 rounded-xl
            shadow-sm hover:shadow-md">

  {% if project.image %}
    <img src="{{ project.image }}"
     class="w-20 h-20 object-cover rounded-lg flex-shrink-0 mt-1 cursor-zoom-in"
     alt="{{ project.name }}"
     onclick="document.getElementById('lightbox-img').src=this.src; document.getElementById('lightbox').classList.remove('hidden'); document.getElementById('lightbox').classList.add('flex')">
  {% endif %}

  <div class="flex flex-col justify-center w-full">

    <div class="flex flex-wrap justify-between items-start mb-1 gap-1">
      <h3 class="text-lg font-semibold">{{ project.name }}</h3>

      <div class="flex gap-2 text-xs text-gray-500 dark:text-gray-400 flex-shrink-0">
        {% if project.year %}
          <span title="created at">📅 {{ project.year }}</span>
        {% endif %}
        {% if project.stars %}
          <span title="stars">⭐ {{ project.stars }}</span>
        {% endif %}
        {% if project.forks %}
          <span title="forks">🍴 {{ project.forks }}</span>
        {% endif %}
        {% if project.status %}
          <span title="{{ project.status }}">
            {% if project.status == 'active' %}🟢
            {% elif project.status == 'archived' %}🟡
            {% endif %}
          </span>
        {% endif %}
      </div>
    </div>

    <p class="text-sm text-gray-600 dark:text-gray-400 mb-2 line-clamp-2">
      {{ project.desc }}
    </p>

    {% if project.tags %}
      <div class="flex flex-wrap gap-2 mb-2">
        {% for tag in project.tags %}
          {% include "project-tag.njk" %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="flex gap-3 mt-1">
      {% if project.repo %}
        <a title="Repository link" href="{{ project.repo }}" target="_blank" class="text-sm font-medium underline">
          View project →
        </a>
      {% endif %}
      {% if project.demo %}
        <a title="Live demo / Deploy link" href="{{ project.demo }}" target="_blank" class="text-sm font-medium underline">
          Live build →
        </a>
      {% endif %}
      {% if project.link %}
        <a title="Main page / Download link" href="{{ project.link }}" target="_blank" class="text-sm font-medium underline">
          Download →
        </a>
      {% endif %}
    </div>

  </div>
</div>